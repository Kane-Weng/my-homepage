# Copy to .env.local for local dev (this file is committed; .env.local is gitignored).
# Both values are safe to expose publicly — the anon key is protected by row-level
# security. Find them in Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
